@@ -47,7 +56,9 @@ RUN set -ex \
 
 RUN alternatives --install /usr/bin/python3 python3 /usr/bin/python3.12 1
 
-RUN pip3.12 install Cython pytest
+RUN pip3.12 install Cython pytest numpy
+
+RUN git config --global --add safe.directory /shared/cuda-quantum
 
 RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
 
@@ -121,6 +132,35 @@ RUN python3.12 -m venv ~/venv \
     && source ~/venv/bin/activate \
     && pip install --upgrade pip
 
+RUN set -euo pipefail \
+    && tmp="$(mktemp -d)" \
+    && cd "$tmp" \
+    && wget -q -O zlib-1.3.1.tar.gz https://github.com/madler/zlib/releases/download/v1.3.1/zlib-1.3.1.tar.gz \
+    && tar -xzf zlib-1.3.1.tar.gz \
+    && cd zlib-1.3.1/contrib/minizip \
+    && gcc -O2 -fPIC -I/usr/include -I../.. -c ioapi.c unzip.c zip.c mztools.c \
+    && ar rcs libminizip.a ioapi.o unzip.o zip.o mztools.o \
+    && install -d /usr/local/zlib/lib /usr/local/zlib/include/minizip \
+    && install -m 0644 libminizip.a /usr/local/zlib/lib/ \
+    && install -m 0644 ioapi.h unzip.h zip.h /usr/local/zlib/include/minizip/ \
+    && rm -rf "$tmp"
+
+RUN cat > /etc/profile.d/cudaq_qrmi_env.sh <<'EOF'
+if command -v python >/dev/null 2>&1; then
+  CUDAQ_SITE_PACKAGES="$(python - <<'PY' 2>/dev/null
+import pathlib
+import cudaq
+print(pathlib.Path(cudaq.__file__).resolve().parent.parent)
+PY
+)"
+  if [ -n "${CUDAQ_SITE_PACKAGES:-}" ]; then
+    CUDAQ_LIB_DIR="${CUDAQ_LIB_DIR:-${CUDAQ_SITE_PACKAGES}/lib}"
+    QRMI_LIB_DIR="${QRMI_LIB_DIR:-/shared/qrmi/target/release}"
+    CUDAQ_QRMI_PLUGIN="${CUDAQ_QRMI_PLUGIN:-${CUDAQ_LIB_DIR}/libcudaq-pasqal-qpu.so}"
+    export LD_LIBRARY_PATH="${CUDAQ_LIB_DIR}:${QRMI_LIB_DIR}:${LD_LIBRARY_PATH:-}"
+    export CUDAQ_DYNLIBS="${CUDAQ_DYNLIBS:-${CUDAQ_QRMI_PLUGIN}}"
+  fi
+fi
+EOF
+
 COPY docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
 ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
